{
  "version": 1,
  "identifier": "default",
  "description": "Default capability allowing access to dialog and file system",
  "windows": ["*"],
  "webviews": ["*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "updater:default"
  ]
}
