  "db_name": "SQLite",
  "query": "\n            SELECT\n                bt.id,\n                bt.transfer_date,\n                bt.amount,\n                bt.transfer_type,\n                bt.bank_account_id,\n                bt.source,\n                ba.id as account_id,\n                ba.name as account_name,\n                ba.iban as account_iban\n            FROM bank_transfer bt\n            JOIN bank_account ba ON bt.bank_account_id = ba.id\n            WHERE bt.is_deleted = 0 AND ba.is_deleted = 0\n            ORDER BY bt.transfer_date DESC\n            ",
